{
  "platform": "CobbleWorks",
  "created_by": "Claude",
  "created_at": "2026-07-02",
  "apps": [
    {
      "id": "restock-planner",
      "name": "Restock Planner",
      "description": "Tap to log how much is left of everyday consumables (body soap, shampoo, etc.) and get a gentle prediction of when you'll need a new one and roughly what it'll cost this month and next.",
      "path": "apps/restock-planner",
      "target_users": "Young people on a tight budget (students, new grads living alone) who get blindsided by irregular but inevitable consumable expenses",
      "status": "published",
      "features": [
        "One-tap stock level logging (Full / Half / Low / Empty) per item",
        "Predicts the next restock date from remaining stock and each item's usual cycle length",
        "This month / next month expected restock spending summary",
        "Gentle due-soon highlighting for items expected to run out within 7 days",
        "Emoji icon picker when adding an item",
        "Friendly, low-pressure microcopy instead of stark budgeting language",
        "localStorage persistence"
      ],
      "integrations": [],
      "files": {
        "html": "apps/restock-planner/index.html",
        "css": "apps/restock-planner/style.css",
        "js": "apps/restock-planner/script.js"
      }
    },
    {
      "id": "company-watchlist",
      "name": "Company Watchlist",
      "description": "Track companies you're interested in. Add notes inline, filter by status, search by industry, and link directly to stock price data.",
      "path": "apps/company-watchlist",
      "target_users": "Job seekers and professionals tracking companies of interest",
      "status": "published",
      "features": [
        "Add companies with name, industry, URL, ticker, notes, and status",
        "Status labels: Watching / Top Choice / Follow Up",
        "Inline note editing (click to edit)",
        "Inline ticker editing (click to add or edit)",
        "Industry search",
        "Status filter buttons",
        "Check price button (links to Stock Checker)",
        "localStorage persistence"
      ],
      "integrations": ["stock-checker"],
      "files": {
        "html": "apps/company-watchlist/index.html",
        "css": "apps/company-watchlist/style.css",
        "js": "apps/company-watchlist/script.js"
      }
    },
    {
      "id": "stock-checker",
      "name": "Stock Price Checker",
      "description": "Look up real-time US stock prices. Quick picks are organized by sector and auto-populated from your Company Watchlist.",
      "path": "apps/stock-checker",
      "target_users": "Investors and job seekers tracking US-listed companies",
      "status": "published",
      "features": [
        "Real-time US stock price lookup via Finnhub API",
        "Quick picks grouped by sector: Tech / Finance / Health / Consumer / Energy",
        "Watchlist section: auto-populated from Company Watchlist tickers",
        "URL parameter support (?ticker=AAPL) for deep linking from other apps",
        "Displays: current price, change, % change, day high/low, open, previous close"
      ],
      "integrations": ["company-watchlist"],
      "requires": {
        "api": "Finnhub (https://finnhub.io)",
        "api_key_location": "apps/stock-checker/script.js — const API_KEY"
      },
      "files": {
        "html": "apps/stock-checker/index.html",
        "css": "apps/stock-checker/style.css",
        "js": "apps/stock-checker/script.js"
      }
    },
    {
      "id": "reference-report-organizer",
      "name": "Reference & Report Organizer",
      "description": "Collect source references (papers, theses, articles) and organize them by which of your own papers/reports they support.",
      "path": "apps/reference-report-organizer",
      "target_users": "Students and researchers who write multiple reports or theses and draw on many references",
      "status": "published",
      "features": [
        "Add and delete papers (your own reports/theses) to group references under",
        "Add, edit, and delete references with title, author(s), URL, summary, personal note",
        "Independently add, edit, and remove multiple key quotes/excerpts per reference, each with its own source (e.g. page number)",
        "Assign a reference to multiple papers via checkboxes",
        "All References view with keyword search across title, authors, summary, and note",
        "By Paper view: select a paper to see full reference detail for drafting",
        "Copy for draft: assembles all references linked to a paper into one clipboard-ready text block",
        "Full data export/import as JSON, merged and deduplicated by id"
      ],
      "integrations": [],
      "fulfills_request": "Thesis/reference collection + report writing support (seed request board)",
      "files": {
        "html": "apps/reference-report-organizer/index.html",
        "css": "apps/reference-report-organizer/style.css",
        "js": "apps/reference-report-organizer/script.js"
      }
    },
    {
      "id": "flashcards-en",
      "name": "English Flashcards",
      "description": "Add English words or phrases and study them as flashcards. Definitions and example sentences are fetched automatically from a free dictionary API and stored for offline review; flip each card to reveal them.",
      "path": "apps/flashcards-en",
      "target_users": "Language learners building English vocabulary who want quick, self-made flashcards without typing out definitions by hand",
      "status": "published",
      "features": [
        "Add a word/phrase; definition, example sentence, and part of speech are auto-fetched from the Free Dictionary API",
        "Manual fallback entry (own definition/example) when the API has no match or is unreachable",
        "Flip-tile card grid: click/tap or keyboard Enter/Space to reveal the back of a card",
        "Search cards by phrase, with a distinct 'no results' state",
        "Shuffle button to reorder cards for review",
        "Delete cards with confirmation",
        "localStorage persistence — no re-fetching on repeat visits"
      ],
      "integrations": [],
      "requires": {
        "api": "Free Dictionary API (https://dictionaryapi.dev), lang=en",
        "api_key_location": "none - public API, no key required"
      },
      "files": {
        "html": "apps/flashcards-en/index.html",
        "css": "apps/flashcards-en/style.css",
        "js": "apps/flashcards-en/script.js"
      }
    },
    {
      "id": "flashcards-es",
      "name": "Spanish Flashcards",
      "description": "Add Spanish words or phrases and study them as flashcards. Definitions and example sentences are fetched automatically from a free dictionary API (with manual entry as a fallback, since Spanish coverage is sparser) and stored for offline review; flip each card to reveal them.",
      "path": "apps/flashcards-es",
      "target_users": "Language learners building Spanish vocabulary who want quick, self-made flashcards without typing out definitions by hand",
      "status": "published",
      "features": [
        "Add a word/phrase; definition, example sentence, and part of speech are auto-fetched from the Free Dictionary API",
        "Manual fallback entry (own definition/example) when the API has no match or is unreachable — expected to trigger often, since this API's Spanish (Wiktionary-derived) dictionary data is currently very sparse",
        "Flip-tile card grid: click/tap or keyboard Enter/Space to reveal the back of a card",
        "Search cards by phrase, with a distinct 'no results' state",
        "Shuffle button to reorder cards for review",
        "Delete cards with confirmation",
        "localStorage persistence — no re-fetching on repeat visits"
      ],
      "integrations": [],
      "requires": {
        "api": "Free Dictionary API (https://dictionaryapi.dev), lang=es",
        "api_key_location": "none - public API, no key required"
      },
      "files": {
        "html": "apps/flashcards-es/index.html",
        "css": "apps/flashcards-es/style.css",
        "js": "apps/flashcards-es/script.js"
      }
    },
    {
      "id": "fan-activity-tracker",
      "name": "Fan Activity Tracker",
      "description": "Track fan activity (event attendance, merch purchases) schedule and spending in one place, with charts, budgets, and a calendar.",
      "path": "apps/fan-activity-tracker",
      "target_users": "Fans tracking events, merch spending, and budgets for their fan activities",
      "status": "published",
      "features": [
        "Expense tracking by category with monthly/category charts and yearly summaries",
        "Monthly budget with over-budget warning",
        "Event calendar and upcoming schedule list, linked to related expenses",
        "Full data export/import as JSON",
        "Japanese / English UI toggle"
      ],
      "integrations": [],
      "tech_note": "Unlike the other apps here, this is a separate React + Vite project (own package.json, IndexedDB via Dexie) built and copied in as a static production bundle — not a vanilla HTML/CSS/JS mini app.",
      "files": {
        "html": "apps/fan-activity-tracker/index.html",
        "bundle": "apps/fan-activity-tracker/assets/"
      }
    }
  ],
